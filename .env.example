# =============================================================================
# Variaveis de Ambiente
# =============================================================================

# Redis Stack (Cache Semantico VSS)
REDIS_URL=redis://localhost:6379

# Embeddings - SentenceTransformers local
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2

# Provedor de LLM
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-openai-api-key-aqui
OPENAI_MODEL_NAME=gpt-4o-mini

# Cache Semantico
SEMANTIC_CACHE_THRESHOLD=0.96

# FlashRank Reranker
RERANKER_MODEL_NAME=ms-marco-MiniLM-L-6-v2

# Limites do Pipeline
TOP_K_VECTOR_DB=20
TOP_K_RERANKER=3
